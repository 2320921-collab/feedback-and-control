
import control
"""
G(s) = N(s)/D(s)
Where:
N(s) = numerator polynomial
D(s) = denominator polynomial

G(s) = 10(s+2)/(s(s+5)(s+10))
Expanded form: 
G(s) = (10s + 20)/(s^3 + 15s^2 + 50s)

"""
'\nG(s) = N(s)/D(s)\nWhere:\nN(s) = numerator polynomial\nD(s) = denominator polynomial\n\nG(s) = 10(s+2)/(s(s+5)(s+10))\nExpanded form: \nG(s) = (10s + 20)/(s^3 + 15s^2 + 50s)\n\n'
num = [10, 20]          # Numerator coefficients
den = [1, 15, 50, 0]    # Denominator coefficients
import control as ctrl
import matplotlib.pyplot as plt

G = ctrl.tf([10, 20], [1, 15, 50, 0 ])
print(G)
<TransferFunction>: sys[0]
Inputs (1): ['u[0]']
Outputs (1): ['y[0]']

       10 s + 20
  -------------------
  s^3 + 15 s^2 + 50 s
t, y = ctrl.step_response(G)
plt.plot(t, y)
plt.xlabel('Time (s)')
plt.ylabel('Output')
plt.grid()
plt.show()

